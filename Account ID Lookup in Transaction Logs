public class AccountSearch {

    // Linear Search: First and Last Occurrence
    public static void linearSearch(String[] arr, String target) {
        int first = -1, last = -1;
        int comparisons = 0;

        for (int i = 0; i < arr.length; i++) {
            comparisons++;
            if (arr[i].equals(target)) {
                if (first == -1) first = i;
                last = i;
            }
        }

        System.out.println("Linear Search:");
        System.out.println("First Occurrence: " + first);
        System.out.println("Last Occurrence: " + last);
        System.out.println("Comparisons: " + comparisons);
        System.out.println("Time Complexity: O(n)");
        System.out.println();
    }

    // Binary Search: Find first occurrence
    public static int binaryFirst(String[] arr, String target, int[] comparisons) {
        int low = 0, high = arr.length - 1;
        int result = -1;

        while (low <= high) {
            comparisons[0]++;
            int mid = (low + high) / 2;

            if (arr[mid].equals(target)) {
                result = mid;
                high = mid - 1; // search left
            } else if (arr[mid].compareTo(target) < 0) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return result;
    }

    // Binary Search: Find last occurrence
    public static int binaryLast(String[] arr, String target, int[] comparisons) {
        int low = 0, high = arr.length - 1;
        int result = -1;

        while (low <= high) {
            comparisons[0]++;
            int mid = (low + high) / 2;

            if (arr[mid].equals(target)) {
                result = mid;
                low = mid + 1; // search right
            } else if (arr[mid].compareTo(target) < 0) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return result;
    }

    // Binary Search Wrapper
    public static void binarySearch(String[] arr, String target) {
        int[] comparisons = {0};

        int first = binaryFirst(arr, target, comparisons);
        int last = binaryLast(arr, target, comparisons);

        int count = (first == -1) ? 0 : (last - first + 1);

        System.out.println("Binary Search:");
        System.out.println("First Occurrence: " + first);
        System.out.println("Last Occurrence: " + last);
        System.out.println("Total Count: " + count);
        System.out.println("Comparisons: " + comparisons[0]);
        System.out.println("Time Complexity: O(log n)");
    }

    // Main Method
    public static void main(String[] args) {
        // IMPORTANT: Binary search requires sorted array
        String[] logs = {"accA", "accB", "accB", "accC"};

        String target = "accB";

        linearSearch(logs, target);
        binarySearch(logs, target);
    }
}
